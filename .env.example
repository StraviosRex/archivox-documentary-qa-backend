# Active LLM profile.
# Available profiles are defined in models.yaml.
#For quick inspection, groq_llama8b, groq_llama70b, ollama_llama32_3b

LLM_PROFILE=groq_llama8b

# API keys.
# Fill in only the provider you plan to use.
# This is only a template. Do not include real keys in this file.
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama does not require an API key.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional manual overrides.
# Leave empty unless you want to override the selected LLM_PROFILE.
LLM_PROVIDER=
LLM_MODEL=
LLM_BASE_URL=

# Retrieval settings
TOP_K=5
SOURCES_IN_RESPONSE=3
SIMILARITY_THRESHOLD=0.48
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking settings
CHUNK_WINDOW_SIZE=3
CHUNK_OVERLAP=1

# Local paths
TRANSCRIPT_PATH=data/transcript.txt
CHROMA_PERSIST_DIR=chroma_db

